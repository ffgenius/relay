#!/usr/bin/env bash
# Auto-format staged Rust files with `cargo fmt` before commit.
#
# - Runs only when staged changes include .rs files.
# - Formats the whole crate (cargo fmt has no per-file mode), then re-stages
#   any files that were already staged so the formatting fix lands in the
#   same commit.
# - Files you had modified but did NOT stage are left as-is (still dirty in
#   the working tree); we only re-add what you'd already chosen to commit.

set -euo pipefail

# Any staged *.rs files? If not, skip.
staged_rs=$(git diff --cached --name-only --diff-filter=ACM -- '*.rs' || true)
if [ -z "$staged_rs" ]; then
    exit 0
fi

# Run formatter. If it fails (parse error etc.), abort the commit.
if ! cargo fmt --all; then
    echo "pre-commit: cargo fmt failed; aborting commit." >&2
    exit 1
fi

# Re-stage only the files that were already staged, in case fmt touched them.
# (We don't blanket `git add .` — that would sweep in unrelated edits.)
echo "$staged_rs" | while IFS= read -r f; do
    [ -n "$f" ] && git add -- "$f"
done
